---
// Footer.astro — 2A source lines 489-501, verbatim. Email link uses plain
// mailto: (same Cloudflare-obfuscation deviation as Hero.astro/About.astro).
---

<footer data-screen-label="Footer" class="brand-skills" style="border-top:1px solid var(--ds-line);margin-top:clamp(48px,7vw,80px)">
	<div style="max-width:1200px;margin:0 auto;padding:34px clamp(20px,5vw,56px) 42px;display:flex;justify-content:space-between;align-items:center;gap:18px 32px;flex-wrap:wrap;box-sizing:border-box">
		<div style="display:inline-flex;align-items:center;gap:11px">
			<span aria-hidden="true" style="width:16px;height:3px;background:var(--ds-accent);display:inline-block"></span>
			<span class="ds-micro" style="color:var(--ds-text-3)">Forged in the Foundry — © 2026 Abhijit Bansal</span>
		</div>
		<div style="display:flex;gap:22px;align-items:center;flex-wrap:wrap">
			<a
				class="ds-micro fy-link-t2"
				href="https://github.com/abhijitbansal"
				target="_blank"
				rel="noopener"
				style="text-decoration:none;transition:color var(--ds-duration-base) var(--ds-ease-standard)"
				>GitHub ↗</a
			>
			<a
				class="ds-micro fy-link-t2"
				href="https://www.linkedin.com/in/abhijitbansal"
				target="_blank"
				rel="noopener"
				style="text-decoration:none;transition:color var(--ds-duration-base) var(--ds-ease-standard)"
				>LinkedIn ↗</a
			>
			<a
				class="ds-micro fy-link-t2"
				href="mailto:contact@abhijitbansal.com"
				style="text-decoration:none;transition:color var(--ds-duration-base) var(--ds-ease-standard)"
				>Email</a
			>
		</div>
		<span class="ds-micro" style="color:var(--ds-text-faint)">No trackers · No analytics · Nothing to consent to</span>
	</div>
</footer>
