---
// Footer.astro — 2A source lines 489-501, verbatim. Email link uses plain
// mailto: (same Cloudflare-obfuscation deviation as Hero.astro/About.astro).
//
// "No trackers..." uses --ds-text-3, not the 2A source's --ds-text-faint
// (acceptance-pass fix, Phase 10): --ds-text-faint on --ds-bg is 1.92:1,
// which Lighthouse flags (WCAG AA needs 4.5:1 for this non-decorative text);
// --ds-text-3 is 4.66:1 and is the token already used one line up for the
// copyright line, so the two stay visually matched. --ds-text-faint is used
// elsewhere in the same non-decorative way (Telemetry captions, "Private
// build" labels) — flagged as a design-token-level follow-up rather than
// patched everywhere here, since that's a broader call than one component.
//
// Egg 1 (design_handoff_eggs/PROMPT.md) — the accent tab is also the
// anvil: a 44×44 unstyled button (negative margins keep layout unchanged)
// that idle-crossfades between the tab and a tiny anvil icon (fy-anvil-*
// keyframes, global.css) and takes three strikes to stamp the footer's
// touchmark. Logic ported from the reference dc.html's strike()/burst().
---

<footer data-screen-label="Footer" class="brand-skills" style="border-top:1px solid var(--ds-line);margin-top:clamp(48px,7vw,80px)">
	<div style="max-width:1200px;margin:0 auto;padding:34px clamp(20px,5vw,56px) 42px;display:flex;justify-content:space-between;align-items:center;gap:18px 32px;flex-wrap:wrap;box-sizing:border-box;position:relative">
		<div style="display:inline-flex;align-items:center;gap:11px">
			<button
				type="button"
				id="fy-anvil"
				class="fy-hold-target"
				title="a smith always leaves a touchmark"
				aria-label="the anvil — strike it"
				style="all:unset;box-sizing:border-box;cursor:pointer;position:relative;display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;margin:-20px -14px;-webkit-tap-highlight-color:transparent"
			>
				<span
					aria-hidden="true"
					class="fy-anvil-row"
					style="width:16px;height:3px;display:inline-block;background:linear-gradient(105deg, var(--ds-accent) 42%, color-mix(in srgb, var(--ds-accent) 40%, white) 50%, var(--ds-accent) 58%);background-size:320% 100%"
				></span>
				<svg
					aria-hidden="true"
					class="fy-anvil-icon"
					viewBox="0 0 24 24"
					width="18"
					height="18"
					style="position:absolute;left:50%;top:50%;transform:translate(-50%, -50%);pointer-events:none"
				>
					<path d="M2 16h13.2l1.8-4h4.6a1 1 0 0 1 1 1v2.2a1.8 1.8 0 0 1-1.8 1.8H17v2h-2v-2H7v2H5v-2H2z" fill="currentColor"></path>
					<rect x="9.5" y="7.4" width="3.6" height="3.6" fill="currentColor"></rect>
					<rect x="10.4" y="3.2" width="1.8" height="4" fill="currentColor"></rect>
				</svg>
				<span aria-hidden="true" class="fy-anvil-flick" style="position:absolute;left:50%;top:50%;width:5px;height:5px;border-radius:50%;background:#D9A93F;transform:translate(-50%, -50%);pointer-events:none"
				></span>
				<span aria-hidden="true" id="fy-anvil-mark" style="position:absolute;left:50%;top:-18px;transform:translateX(-50%);font:600 10px var(--ds-font-mono);letter-spacing:0.12em;color:var(--ds-accent);white-space:nowrap;display:none"
				></span>
				<span aria-hidden="true" id="fy-anvil-sparks" style="position:absolute;left:50%;top:50%;width:0;height:0;overflow:visible;pointer-events:none"></span>
			</button>
			<span class="ds-micro" id="fy-footer-copy1" style="color:var(--ds-text-3)">Forged in the Foundry — © 2026 Abhijit Bansal</span>
		</div>
		<div style="display:flex;gap:22px;align-items:center;flex-wrap:wrap">
			<a
				class="ds-micro fy-link-t2"
				href="https://github.com/abhijitbansal"
				target="_blank"
				rel="noopener"
				style="text-decoration:none;transition:color var(--ds-duration-base) var(--ds-ease-standard)"
				>GitHub ↗</a
			>
			<a
				class="ds-micro fy-link-t2"
				href="https://www.linkedin.com/in/abhijit-bansal/"
				target="_blank"
				rel="noopener"
				style="text-decoration:none;transition:color var(--ds-duration-base) var(--ds-ease-standard)"
				>LinkedIn ↗</a
			>
			<a
				class="ds-micro fy-link-t2"
				href="mailto:contact@abhijitbansal.com"
				style="text-decoration:none;transition:color var(--ds-duration-base) var(--ds-ease-standard)"
				>Email</a
			>
		</div>
		<span class="ds-micro" id="fy-footer-copy2" style="color:var(--ds-text-3)">No trackers · No analytics · Nothing to consent to</span>

		<div aria-hidden="true" id="fy-seal" style="position:absolute;right:clamp(18px,7vw,110px);top:-30px;width:96px;height:96px;pointer-events:none;mix-blend-mode:multiply;z-index:4;display:none">
			<svg width="96" height="96" viewBox="0 0 92 92">
				<defs>
					<path id="fySealArc" d="M 46 10 a 36 36 0 1 1 -0.05 0" fill="none"></path>
				</defs>
				<circle cx="46" cy="46" r="44" fill="none" stroke="var(--ds-accent-hover)" stroke-width="1.4" opacity="0.9"></circle>
				<circle cx="46" cy="46" r="41.5" fill="none" stroke="var(--ds-accent-hover)" stroke-width="0.6" stroke-dasharray="1.5 3" opacity="0.75"></circle>
				<circle cx="46" cy="46" r="28.5" fill="none" stroke="var(--ds-accent-hover)" stroke-width="0.8" opacity="0.85"></circle>
				<text style="font-family:var(--ds-font-mono);font-size:6.4px;font-weight:600;letter-spacing:0.16em;fill:var(--ds-accent-hover)"
					><textPath href="#fySealArc" startOffset="2">STRUCK BY HAND · THE FOUNDRY · MMXXVI</textPath></text
				>
				<text x="46" y="50" text-anchor="middle" style="font-family:var(--ds-font-display);font-size:24px;fill:var(--ds-accent-hover)">AB</text>
				<rect x="38" y="56" width="16" height="2.6" fill="var(--ds-accent-hover)"></rect>
				<text x="46" y="68" text-anchor="middle" style="font-family:var(--ds-font-mono);font-size:5.6px;letter-spacing:0.12em;fill:var(--ds-accent-hover)">№ 001</text>
			</svg>
		</div>
	</div>
</footer>

<script>
	import { readFlag, reducedMotion, stampThud, tink, writeFlag } from '../lib/eggs';

	const btn = document.getElementById('fy-anvil');
	const markEl = document.getElementById('fy-anvil-mark');
	const sparksEl = document.getElementById('fy-anvil-sparks');
	const seal = document.getElementById('fy-seal');
	const copy1 = document.getElementById('fy-footer-copy1');
	const copy2 = document.getElementById('fy-footer-copy2');

	if (btn instanceof HTMLButtonElement && markEl && sparksEl && seal && copy1 && copy2) {
		let strikes = 0;
		let stamped = readFlag('fy-touchmark');
		let clearSparksTimer: ReturnType<typeof setTimeout> | null = null;

		function applyCopy() {
			copy1!.textContent = stamped ? 'Touchmark № 001 · struck by hand — © 2026 Abhijit Bansal' : 'Forged in the Foundry — © 2026 Abhijit Bansal';
			copy2!.textContent = stamped ? "You found the smith's mark · it holds till the fire goes cold" : 'No trackers · No analytics · Nothing to consent to';
		}

		function burst(count: number, gold: boolean) {
			if (reducedMotion) return;
			if (clearSparksTimer) clearTimeout(clearSparksTimer);
			sparksEl!.innerHTML = '';
			for (let i = 0; i < count; i++) {
				const a = -Math.PI / 2 + (Math.random() - 0.5) * 2.6;
				const dist = (gold ? 26 : 18) + Math.random() * (gold ? 68 : 48);
				const dx = Math.round(Math.cos(a) * dist);
				const dy = Math.round(Math.sin(a) * dist);
				const size = (2 + Math.random() * 1.6).toFixed(1);
				const color = Math.random() < (gold ? 0.85 : 0.6) ? '#D9A93F' : 'var(--ds-accent)';
				const delay = Math.floor(Math.random() * 70) + 'ms';
				const span = document.createElement('span');
				span.style.cssText = `position:absolute;left:0;top:0;width:${size}px;height:${size}px;border-radius:50%;background:${color};--dx:${dx}px;--dy:${dy}px;animation:fy-spark 0.7s cubic-bezier(0.16,1,0.3,1) ${delay} forwards`;
				sparksEl!.appendChild(span);
			}
			clearSparksTimer = setTimeout(() => {
				clearSparksTimer = null;
				sparksEl!.innerHTML = '';
			}, 850);
		}

		function showMark(text: string) {
			if (reducedMotion) return;
			markEl!.textContent = text;
			markEl!.style.display = 'block';
			markEl!.style.animation = 'none';
			void markEl!.offsetWidth;
			markEl!.style.animation = 'fy-fadeup 1.3s var(--ds-ease-standard) forwards';
		}

		function stampIn(instant: boolean) {
			seal!.style.display = 'block';
			seal!.style.animation = instant || reducedMotion ? 'none' : 'fy-stamp 0.45s cubic-bezier(0.2,0.9,0.3,1.2) forwards';
		}

		if (stamped) {
			applyCopy();
			stampIn(true);
		}

		btn.addEventListener('click', () => {
			if (stamped) {
				tink(0);
				return;
			}
			const n = strikes + 1;
			burst(n === 3 ? 22 : 10, n === 3);
			if (n >= 3) {
				stampThud();
				setTimeout(() => tink(2), 70);
				strikes = 0;
				stamped = true;
				writeFlag('fy-touchmark', true);
				markEl!.style.display = 'none';
				applyCopy();
				stampIn(false);
			} else {
				tink(n - 1);
				strikes = n;
				showMark(n === 1 ? 'I' : 'II');
			}
		});
	}
</script>
