---
// WorkSection.astro — 2A source lines 132-281. Assembles the kicker/H1/lead/
// rule, the three WorkGroups (Apps -> AI/agent tooling -> Foundation, source
// order), then the "In the forge" callout, verbatim copy.
import WorkGroup from './WorkGroup.astro';
import { appsProjects, aiToolingProjects, foundationProjects } from '../data/projects';
---

<section id="work" data-screen-label="Work" style="position:relative;scroll-margin-top:72px">
	<div style="max-width:1200px;margin:0 auto;padding:clamp(48px,7vw,88px) clamp(20px,5vw,56px) 0;box-sizing:border-box">
		<div data-reveal>
			<p class="ds-kicker" style="margin:0 0 12px">02 · The work</p>
			<h2 class="ds-display-lg" style="margin:0">Forged here.</h2>
			<p class="ds-lead" style="margin:14px 0 0;max-width:58ch;text-wrap:pretty">
				Nine projects across apps, agent tooling, and foundation. Private builds tell their story here; public ones link to
				source.
			</p>
			<hr class="ds-rule" style="margin-top:18px" />
		</div>

		<WorkGroup
			label="Apps — iOS & macOS"
			count="04"
			headerMargin="clamp(28px,4vw,48px)"
			projects={appsProjects}
			startIndex={1}
		/>
		<WorkGroup
			label="AI / agent tooling"
			count="04"
			headerMargin="clamp(36px,5vw,56px)"
			projects={aiToolingProjects}
			startIndex={5}
		/>
		<WorkGroup
			label="Foundation"
			count="01"
			headerMargin="clamp(36px,5vw,56px)"
			projects={foundationProjects}
			startIndex={9}
		/>

		<aside
			data-reveal
			class="ds-callout"
			style="margin-top:clamp(36px,5vw,56px);display:flex;justify-content:space-between;align-items:center;gap:20px;flex-wrap:wrap;padding:22px 26px"
		>
			<div style="display:flex;flex-direction:column;gap:9px;max-width:72ch">
				<span class="ds-kicker">In the forge</span>
				<p class="ds-body" style="margin:0;color:var(--ds-text)">
					A personal financial adviser, and more personal infrastructure. The theme holds:{' '}
					<em style="font-family:var(--ds-font-display)">build my own tools instead of renting mediocre ones.</em>
				</p>
			</div>
			<span class="ds-pill" style="--ds-success:var(--ds-info)">heating up</span>
		</aside>
	</div>
</section>
