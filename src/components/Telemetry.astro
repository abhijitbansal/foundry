---
// Telemetry.astro — plan Task 5.3. Structure + copy verbatim from 2A
// source lines 283-457; every number below is now derived at build time
// from data/stats.json via src/lib/telemetry.ts (Phase 3's hardcoded
// snapshot values are gone). Heatmap cell generation lives in
// Heatmap.astro. The activity card is anchored at TELEMETRY_START_ISO
// (May 1, 2026) through the latest data day — "always everything from
// May 1st onwards", not a trailing 30-day window.
import Heatmap from './Heatmap.astro';
import statsJson from '../../data/stats.json';
import type { StatsJson } from '../lib/telemetry.types';
import {
	formatCompact,
	TELEMETRY_START_ISO,
	dateRangeCells,
	rangeSum,
	peakDayInRange,
	modelMixSegments,
	topToolBars,
	memekitTerminal,
	lookupCount,
	formatDateRange,
	daysBetweenInclusive,
	heatmapAriaLabel,
} from '../lib/telemetry';

const stats = statsJson as unknown as StatsJson;
const { meta, totals } = stats;

const dailyOutTokens = Object.fromEntries(stats.daily_out_tokens);
const dailySessions = Object.fromEntries(stats.daily_sessions);
const dailyLines = Object.fromEntries(stats.daily_lines);

const filesFound = formatCompact(meta.files_found);
const dateRange = formatDateRange(meta.date_min, meta.date_max);
const daysSpan = daysBetweenInclusive(meta.date_min, meta.date_max);

const heatmapCells = dateRangeCells(dailyOutTokens, TELEMETRY_START_ISO, meta.date_max);
const windowStartLabel = heatmapCells[0].label;
const windowEndLabel = heatmapCells[heatmapCells.length - 1].label;
const heatmapLabel = heatmapAriaLabel(heatmapCells);

const windowSessions = rangeSum(dailySessions, TELEMETRY_START_ISO, meta.date_max);
const windowLines = rangeSum(dailyLines, TELEMETRY_START_ISO, meta.date_max);
const windowTokensOut = rangeSum(dailyOutTokens, TELEMETRY_START_ISO, meta.date_max);
const peakSessionsDay = peakDayInRange(dailySessions, TELEMETRY_START_ISO, meta.date_max);

const modelSegments = modelMixSegments(stats.models, totals.assistant_msgs);
const toolBars = topToolBars(stats.top_tools, 5);

const thinkingBlocks = formatCompact(totals.thinking_blocks);
const subagentRuns = formatCompact(lookupCount(stats.top_tools, 'Agent'));
const skillInvocations = formatCompact(lookupCount(stats.top_tools, 'Skill'));
const compactCount = lookupCount(stats.top_slash, '/compact');
const longestPrompt = formatCompact(stats.global_prompts.max);
const cubbyScreenshots = stats.repos.find((r) => r.repo === 'cubby')?.image_count ?? 0;

const memekitLines = memekitTerminal(totals.in_tokens, totals.out_tokens, totals.cache_read_tokens);
---

<section id="telemetry" data-screen-label="Telemetry" style="position:relative;scroll-margin-top:72px">
	<div style="max-width:1200px;margin:0 auto;padding:clamp(64px,9vw,110px) clamp(20px,5vw,56px) 0;box-sizing:border-box">
		<div data-reveal>
			<p class="ds-kicker" style="margin:0 0 12px">03 · Forge telemetry</p>
			<h2 class="ds-display-lg" style="margin:0">The forge runs hot.</h2>
			<p class="ds-lead" style="margin:14px 0 0;max-width:60ch;text-wrap:pretty">
				Everything above is built with Claude Code — and the workshop keeps its own books. Parsed locally from {filesFound}{' '}
				session logs, {dateRange}.
			</p>
			<hr class="ds-rule" style="margin-top:18px" />
		</div>

		<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(180px,100%),1fr));gap:clamp(16px,2vw,26px);margin-top:clamp(26px,4vw,42px)">
			<div data-reveal style="border-top:1px solid var(--ds-line);padding-top:18px;display:flex;flex-direction:column;gap:7px">
				<span class="ds-display-lg">{formatCompact(totals.lines_added)}</span>
				<span class="ds-micro" style="color:var(--ds-accent-hover)">Lines added</span>
				<span class="ds-caption">across every repo, {daysSpan} days</span>
			</div>
			<div data-reveal style="border-top:1px solid var(--ds-line);padding-top:18px;display:flex;flex-direction:column;gap:7px">
				<span class="ds-display-lg">{formatCompact(totals.sessions)}</span>
				<span class="ds-micro" style="color:var(--ds-accent-hover)">Sessions</span>
				<span class="ds-caption">{formatCompact(totals.user_msgs)} prompts · {formatCompact(totals.assistant_msgs)} replies</span>
			</div>
			<div data-reveal style="border-top:1px solid var(--ds-line);padding-top:18px;display:flex;flex-direction:column;gap:7px">
				<span class="ds-display-lg">{formatCompact(totals.out_tokens)}</span>
				<span class="ds-micro" style="color:var(--ds-accent-hover)">Tokens written</span>
				<span class="ds-caption">output, straight into the melt</span>
			</div>
			<div data-reveal style="border-top:1px solid var(--ds-line);padding-top:18px;display:flex;flex-direction:column;gap:7px">
				<span class="ds-display-lg">{formatCompact(totals.cache_read_tokens)}</span>
				<span class="ds-micro" style="color:var(--ds-accent-hover)">Tokens cache-read</span>
				<span class="ds-caption">the crucible remembers</span>
			</div>
		</div>

		<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(380px,100%),1fr));gap:20px;margin-top:clamp(26px,4vw,40px);align-items:stretch">
			<article data-reveal style="display:flex;flex-direction:column;gap:18px;background:var(--ds-surface);border:1px solid var(--ds-line);border-radius:var(--ds-radius-lg);padding:24px 26px">
				<div style="display:flex;justify-content:space-between;align-items:baseline;gap:12px;flex-wrap:wrap">
					<span class="ds-micro" style="color:var(--ds-accent-hover)">Since May 1</span>
					<span class="ds-micro" style="color:var(--ds-text-faint)">{windowStartLabel} – {windowEndLabel} · out-tokens per day</span>
				</div>
				<div style="display:flex;gap:clamp(18px,3vw,32px);align-items:flex-start;flex-wrap:wrap">
					<Heatmap cells={heatmapCells} ariaLabel={heatmapLabel} />
					<div style="display:flex;flex-direction:column;gap:14px;flex:1;min-width:150px">
						<div style="display:flex;flex-direction:column;gap:3px">
							<span class="ds-display-md">{formatCompact(windowSessions)}</span>
							<span class="ds-micro" style="color:var(--ds-text-3)">Sessions</span>
						</div>
						<div style="display:flex;flex-direction:column;gap:3px">
							<span class="ds-display-md">{formatCompact(windowLines)}</span>
							<span class="ds-micro" style="color:var(--ds-text-3)">Lines added</span>
						</div>
						<div style="display:flex;flex-direction:column;gap:3px">
							<span class="ds-display-md">{formatCompact(windowTokensOut)}</span>
							<span class="ds-micro" style="color:var(--ds-text-3)">Tokens out</span>
						</div>
					</div>
				</div>
				<div style="margin-top:auto;display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;border-top:1px solid var(--ds-line);padding-top:14px">
					<span class="ds-caption">
						{peakSessionsDay && (
							<>
								Peak: {peakSessionsDay.label} — {formatCompact(peakSessionsDay.value)} sessions in one day
							</>
						)}
					</span>
					<span style="display:inline-flex;align-items:center;gap:4px">
						<span class="ds-micro" style="color:var(--ds-text-faint);margin-right:4px">cool</span>
						<span style="width:12px;height:12px;border-radius:3px;background:var(--ds-surface-2);border:1px solid var(--ds-line);box-sizing:border-box"></span>
						<span style="width:12px;height:12px;border-radius:3px;background:color-mix(in srgb, var(--ds-accent) 28%, var(--ds-surface-2))"></span>
						<span style="width:12px;height:12px;border-radius:3px;background:color-mix(in srgb, var(--ds-accent) 55%, var(--ds-surface-2))"></span>
						<span style="width:12px;height:12px;border-radius:3px;background:var(--ds-accent)"></span>
						<span style="width:12px;height:12px;border-radius:3px;background:var(--ds-secondary)"></span>
						<span class="ds-micro" style="color:var(--ds-text-faint);margin-left:4px">hot</span>
					</span>
				</div>
			</article>

			<div style="display:flex;flex-direction:column;gap:20px">
				<article data-reveal style="display:flex;flex-direction:column;gap:16px;background:var(--ds-surface);border:1px solid var(--ds-line);border-radius:var(--ds-radius-lg);padding:24px 26px">
					<div style="display:flex;justify-content:space-between;align-items:baseline;gap:12px;flex-wrap:wrap">
						<span class="ds-micro" style="color:var(--ds-accent-hover)">Model mix</span>
						<span class="ds-micro" style="color:var(--ds-text-faint)">{formatCompact(totals.assistant_msgs)} assistant messages</span>
					</div>
					<div aria-hidden="true" style="display:flex;height:8px;border-radius:var(--ds-radius-pill);overflow:hidden">
						{modelSegments.map((seg) => <span style={`width:${seg.percent}%;background:${seg.colorVar}`} />)}
					</div>
					<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:9px 18px">
						{modelSegments.map((seg) => (
							<span style="display:inline-flex;align-items:center;gap:8px">
								<span style={`width:7px;height:7px;border-radius:50%;background:${seg.colorVar};flex:none`}></span>
								<span class="ds-micro" style="color:var(--ds-text-2)">
									{seg.label} · {seg.percent}%
								</span>
							</span>
						))}
					</div>
				</article>

				<article data-reveal style="display:flex;flex-direction:column;gap:14px;background:var(--ds-surface);border:1px solid var(--ds-line);border-radius:var(--ds-radius-lg);padding:24px 26px">
					<span class="ds-micro" style="color:var(--ds-accent-hover)">Top tools</span>
					{toolBars.map((bar) => (
						<div style="display:flex;flex-direction:column;gap:5px">
							<div style="display:flex;justify-content:space-between;gap:12px">
								<span class="ds-micro" style="color:var(--ds-text-2)">{bar.label}</span>
								<span class="ds-micro" style="color:var(--ds-text-3)">{formatCompact(bar.count)}</span>
							</div>
							<div aria-hidden="true" style="height:3px;background:var(--ds-line);border-radius:2px">
								<div style={`width:${bar.percent}%;height:3px;background:var(--ds-accent);border-radius:2px`}></div>
							</div>
						</div>
					))}
				</article>
			</div>
		</div>

		<div data-reveal style="display:flex;gap:10px;flex-wrap:wrap;margin-top:22px">
			<span class="ds-chip">{thinkingBlocks} thinking blocks</span>
			<span class="ds-chip">{subagentRuns} subagent runs</span>
			<span class="ds-chip">{skillInvocations} skill invocations</span>
			<span class="ds-chip">/compact × {compactCount}</span>
			<span class="ds-chip">longest prompt: {longestPrompt} chars</span>
			<span class="ds-chip">{cubbyScreenshots} screenshots into cubby</span>
		</div>

		<aside data-reveal style="margin-top:22px;background:var(--ds-surface-2);border:1px solid var(--ds-line);border-radius:var(--ds-radius-lg);overflow:hidden;max-width:760px">
			<div style="display:flex;justify-content:space-between;align-items:center;gap:12px;padding:11px 20px;border-bottom:1px solid var(--ds-line)">
				<span class="ds-micro" style="color:var(--ds-text-3)">$ memekit react --to "the token ledger"</span>
				<span class="ds-micro" style="color:var(--ds-text-faint)">80×24</span>
			</div>
			<pre style="margin:0;padding:20px 24px;font-family:var(--ds-font-mono);font-size:12.5px;line-height:1.65;color:var(--ds-text-2);overflow-x:auto">{memekitLines[0]}
{memekitLines[1]}
{memekitLines[2]}

(ノ°□°)ノ ︵ ┻━┻      the ledger, first read
┬─┬ ノ( ゜-゜ノ)      the ledger, accepted

<span style="color:var(--ds-accent-hover)">0 regrets · {formatCompact(totals.lines_added)} lines shipped</span></pre>
		</aside>

		<p class="ds-caption" data-reveal style="margin:18px 0 0;max-width:72ch;text-wrap:pretty">
			Counted from {filesFound} local session logs by a{' '}
			<a
				href="https://github.com/abhijitbansal/claude-skills"
				target="_blank"
				rel="noopener"
				class="fy-link-underline"
				style="color:var(--ds-accent-hover);text-decoration:none;transition:border-color var(--ds-duration-base) var(--ds-ease-standard)"
				>claude-skills</a
			>{' '}script — on-device, like everything else here. Regenerated at each deploy.
		</p>
	</div>
</section>
