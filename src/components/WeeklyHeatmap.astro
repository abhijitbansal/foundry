---
// WeeklyHeatmap.astro — the 7 (weekday) x 24 (hour) activity grid for one
// week's digest, consuming a WeeklyHeatmap (src/lib/weekly.types.ts). Same
// role="img" + aria-label + per-cell title pattern as the main page's
// Heatmap.astro, but intensity is normalized on message count per hour,
// not out_tokens like the main page's day-level heatmap — see the comment
// on maxHeatmapValue() (src/lib/weekly.ts) for why. out_tokens still shows
// in the tooltip as extra detail when a cell has activity.
import { heatmapCellColor, heatmapCellPercent, maxHeatmapValue } from '../lib/weekly';
import { formatCompact } from '../lib/telemetry';
import type { WeeklyHeatmap } from '../lib/weekly.types';

interface Props {
	heatmap: WeeklyHeatmap;
}

const { heatmap } = Astro.props;
const max = maxHeatmapValue(heatmap.cells);
const ariaLabel = `Activity by hour and day of week, ${heatmap.timezone} time`;
---

<div style="display:flex;gap:8px">
	<div style="display:flex;flex-direction:column;gap:3px;justify-content:space-between;padding-top:2px">
		{heatmap.weekday_labels.map((label) => <span class="ds-micro" style="color:var(--ds-text-faint);height:11px;line-height:11px">{label}</span>)}
	</div>
	<div
		role="img"
		aria-label={ariaLabel}
		style="display:grid;grid-template-rows:repeat(7,11px);grid-auto-columns:11px;grid-auto-flow:column;gap:3px;overflow-x:auto"
	>
		{
			Array.from({ length: 24 }, (_, hour) =>
				heatmap.cells.map((row, weekday) => {
					const cell = row[hour];
					const percent = heatmapCellPercent(cell.count, max);
					const title =
						percent === 0
							? `${heatmap.weekday_labels[weekday]} ${hour}:00 — quiet`
							: `${heatmap.weekday_labels[weekday]} ${hour}:00 — ${formatCompact(cell.count)} messages, ${formatCompact(cell.out_tokens)} tokens out`;
					const border = percent === 0 ? ';border:1px solid var(--ds-line);box-sizing:border-box' : '';
					return <span title={title} style={`border-radius:2px;background:${heatmapCellColor(percent)}${border}`} />;
				})
			)
		}
	</div>
</div>
<p class="ds-caption" style="margin:8px 0 0;color:var(--ds-text-faint)">Hour of day ({heatmap.timezone}), left to right = midnight to 11pm.</p>
