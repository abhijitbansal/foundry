---
// HarnessScore.astro — id harness-score, "06 · The audit". Kicker/h2/lead/
// rule, the dims bar-chart article (dims copied verbatim from the reference
// DC script's local array, dc.html lines ~497-504), the "Still weak"
// warning callout, and the Loop SVG figure. Verbatim from dc.html
// lines ~357-398.
import { buildLoop } from '../../lib/harness-svg';

interface Dim {
	name: string;
	score: string;
	pct: string;
	note: string;
	fill: string;
}

const dims: Dim[] = [
	{ name: 'Workflow & orchestration', score: '17 / 20', pct: '85%', note: 'strongest layer — still prose-enforced', fill: 'var(--ds-accent)' },
	{ name: 'Hooks & enforcement', score: '16 / 18', pct: '89%', note: 'bash-guard hardened, 20/20 fixtures live', fill: 'var(--ds-accent)' },
	{ name: 'Recorders, memory & checkpoints', score: '12 / 17', pct: '71%', note: 'instinct pile uncurated and growing', fill: 'var(--ds-secondary)' },
	{ name: 'Skills ecosystem', score: '10 / 15', pct: '67%', note: 'precedence declared; sprawl unchanged', fill: 'var(--ds-secondary)' },
	{ name: 'Safety, cost & token control', score: '11 / 15', pct: '73%', note: 'allowlist narrowing deferred by choice', fill: 'var(--ds-secondary)' },
	{ name: 'Documentation', score: '13 / 15', pct: '87%', note: 'every rule traces to an incident', fill: 'var(--ds-accent)' },
];
---

<section id="harness-score" data-screen-label="06 Score" style="scroll-margin-top:72px">
	<div style="max-width:1200px;margin:0 auto;padding:clamp(64px,9vw,110px) clamp(20px,5vw,56px) 0;box-sizing:border-box;display:flex;flex-direction:column;gap:26px">
		<div>
			<p class="ds-kicker" style="margin:0 0 12px">06 · The audit</p>
			<h2 class="ds-display-lg" style="margin:0">79/100, and what that number hides.</h2>
			<p class="ds-lead" style="margin:14px 0 0;max-width:62ch;text-wrap:pretty">Six agents read the actual config; an independent planner-tier pass scored it and refuted two of its own draft findings. Up from 73 — driven by real repo-scoped enforcement — and stale by its own rules until the next re-score.</p>
			<hr class="ds-rule" style="margin-top:16px" />
		</div>
		<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(420px,100%),1fr));gap:clamp(18px,3vw,36px);align-items:start">
			<article style="background:var(--ds-surface);border:1px solid var(--ds-line);border-radius:var(--ds-radius-lg);padding:clamp(18px,2.6vw,28px);display:flex;flex-direction:column;gap:16px">
				<span class="ds-micro" style="color:var(--ds-text-3)">Dimension scores — independent re-score, 2026-07-12</span>
				{dims.map((d) => (
					<div style="display:flex;flex-direction:column;gap:5px">
						<div style="display:flex;justify-content:space-between;gap:12px;align-items:baseline">
							<span class="ds-body-sm" style="color:var(--ds-text)">{d.name}</span>
							<span class="ds-micro" style="color:var(--ds-accent-hover)">{d.score}</span>
						</div>
						<div style="height:4px;background:var(--ds-surface-2);border:1px solid var(--ds-line);border-radius:2px;overflow:hidden">
							<div style={`height:100%;width:${d.pct};background:${d.fill}`}></div>
						</div>
						<span class="ds-caption" style="color:var(--ds-text-3)">{d.note}</span>
					</div>
				))}
			</article>
			<div style="display:flex;flex-direction:column;gap:16px">
				<article style="border:1px solid var(--ds-line);border-radius:var(--ds-radius-lg);padding:clamp(18px,2.6vw,28px);display:flex;flex-direction:column;gap:12px;background:color-mix(in srgb, var(--ds-warning) 4%, var(--ds-surface))">
					<span class="ds-micro" style="color:var(--ds-warning)">Still weak — on the record</span>
					<ul style="margin:0;padding-left:18px;display:flex;flex-direction:column;gap:9px">
						<li class="ds-body-sm" style="color:var(--ds-text-2)">272 banked instincts, uncurated — the observer that minted them is paused after ~92 failed runs; pruning found zero safe deletions.</li>
						<li class="ds-body-sm" style="color:var(--ds-text-2)">~360 installed skills across four populations that were never designed together; Swift 6 concurrency alone has 5–6 overlapping sources.</li>
						<li class="ds-body-sm" style="color:var(--ds-text-2)">The push and stop-log gates verify that a checkpoint <em>ritual</em> happened, not that tests ran or a review was real.</li>
						<li class="ds-body-sm" style="color:var(--ds-text-2)">The permission allowlist still auto-approves a few destructive shapes; narrowing it was deliberately deferred.</li>
					</ul>
					<span class="ds-caption" style="color:var(--ds-text-3)">Full method + scorecard: docs/harness/EVALUATION.md · architecture: docs/harness/ARCHITECTURE.md</span>
				</article>
				<article style="border:1px solid var(--ds-line);border-radius:var(--ds-radius-lg);padding:clamp(14px,2vw,20px);background:var(--ds-surface)">
					<Fragment set:html={buildLoop()} />
				</article>
			</div>
		</div>
	</div>
</section>
